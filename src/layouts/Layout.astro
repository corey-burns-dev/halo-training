---
import { CartDrawer } from "../components/CartDrawer";
import Footer from "../components/Footer.astro";
import { MobileMenu } from "../components/MobileMenu";
import Navbar from "../components/Navbar.astro";
import "../index.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const navItems = ["Footwear", "Apparel", "Accessories", "Training"];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    <meta name="description" content="Halo Training — Fitness and wellness programs. Train smarter, recover better." />
    <meta name="theme-color" content="#0f172a" />
		<title>{title} | AXIS TRAINING</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-brand-dark text-white font-sans selection:bg-brand-primary selection:text-brand-dark">
    <div id="layout-root" class="opacity-0 transition-opacity duration-1000">
      <!-- Dynamic Background -->
      <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
        <div class="absolute top-[-20%] right-[-10%] w-[60%] h-[60%] rounded-full bg-brand-primary opacity-[0.05] blur-[150px] animate-[pulse_4s_ease-in-out_infinite]" />
        <div class="absolute top-[40%] left-[-20%] w-[50%] h-[50%] rounded-full bg-brand-secondary opacity-[0.03] blur-[150px]" />

        <!-- Slanted lines -->
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+CiAgPHBhdGggZD0iTTAgNDBMNDAgMCIgc3Ryb2tlPSJibGFjayIgc3Ryb2tlLXdpZHRoPSIyIiBvcGFjaXR5PSIwLjEiLz4KPC9zdmc+')] opacity-20 mix-blend-overlay" />
      </div>

      <Navbar navItems={navItems} />

      <MobileMenu client:load navItems={navItems} />
      <CartDrawer client:load />

      <main class="relative z-10 w-full min-h-screen">
        <slot />
      </main>

      <Footer />
    </div>

    <script>
      // Handle the fade-in animation
      window.addEventListener('DOMContentLoaded', () => {
        document.getElementById('layout-root')?.classList.remove('opacity-0');
        document.getElementById('layout-root')?.classList.add('opacity-100');
      });
    </script>
	</body>
</html>

<style is:global>
  @keyframes pulse {
    0%, 100% { opacity: 0.05; transform: scale(1); }
    50% { opacity: 0.08; transform: scale(1.1); }
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #00FF94;
  }
</style>
