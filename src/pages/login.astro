---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { ArrowRight, Zap } from "lucide-react";
---

<Layout title="Login">
  <div class="min-h-screen pt-32 px-6 md:px-12 flex items-center justify-center relative z-10 pb-32">
    <div class="w-full max-w-md bg-brand-surface p-10 border-t-4 border-brand-primary relative group">
      <div class="absolute -top-4 -right-4 w-12 h-12 border-t-2 border-r-2 border-brand-secondary opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="absolute -bottom-4 -left-4 w-12 h-12 border-b-2 border-l-2 border-brand-primary opacity-0 group-hover:opacity-100 transition-opacity"></div>

      <div class="flex justify-center mb-8">
        <Zap
          size={48}
          class="text-brand-primary animate-[pulse_2s_ease-in-out_infinite]"
          fill="currentColor"
        />
      </div>

      <h2 class="text-3xl font-black italic uppercase tracking-tighter text-white mb-2 text-center">
        ACCESS <span class="text-brand-primary">SYSTEM</span>
      </h2>
      <p class="text-white/50 text-center font-bold text-sm tracking-widest uppercase mb-10">
        Identify yourself to proceed
      </p>

      <form class="space-y-6">
        <div class="relative">
          <input
            type="email"
            placeholder="OPERATIVE EMAIL"
            class="w-full bg-transparent border-b-2 border-white/20 px-4 py-3 text-white font-bold tracking-widest uppercase outline-none focus:border-brand-primary transition-colors placeholder:text-white/20"
          />
        </div>
        <div class="relative">
          <input
            type="password"
            placeholder="PASSCODE"
            class="w-full bg-transparent border-b-2 border-white/20 px-4 py-3 text-white font-bold tracking-widest uppercase outline-none focus:border-brand-primary transition-colors placeholder:text-white/20"
          />
        </div>

        <div class="flex justify-between items-center text-xs font-bold tracking-widest uppercase pt-2">
          <label class="flex items-center gap-2 cursor-pointer group">
            <div class="w-4 h-4 border-2 border-white/20 group-hover:border-brand-primary transition-colors relative">
              <input
                type="checkbox"
                class="absolute opacity-0 cursor-pointer"
              />
            </div>
            <span class="text-white/60 group-hover:text-white transition-colors">
              Remember me
            </span>
          </label>
          <a
            href="/"
            class="text-brand-secondary hover:text-brand-primary transition-colors"
          >
            Reset Code
          </a>
        </div>

        <Button type="button" class="w-full mt-8" variant="primary">
          <span class="flex items-center justify-center gap-3 w-full">
            INITIATE LOGIN
            <ArrowRight
              size={20}
              class="transform group-hover:translate-x-2 transition-all duration-300"
            />
          </span>
        </Button>
      </form>

      <div class="mt-8 text-center border-t border-white/10 pt-8">
        <p class="text-white/40 font-bold text-xs tracking-widest uppercase">
          Not registered?{" "}
          <a
            href="/"
            class="text-brand-primary hover:text-white transition-colors"
          >
            Join the Unit
          </a>
        </p>
      </div>
    </div>
  </div>
</Layout>
